# LLM Provider (used by the Agentic layer in Milestone 2)
GROQ_API_KEY=your_groq_api_key_here

# ChromaDB Mode: set to "false" for local (recommended), "true" for Chroma Cloud
USE_CHROMA_CLOUD=false

# Chroma Cloud Credentials (only needed if USE_CHROMA_CLOUD=true)
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_tenant_id_here
CHROMA_DATABASE=customer-churn
